// `opaque predicate` is accepted; the predicate's underlying
// `define` and `recursive` validator inherit the visibility, while
// the auto-generated intro theorems remain accessible by name as
// usual. Within the same file the synthesised proofs still expand
// the predicate as needed.

import UInt

opaque predicate even : fn UInt -> bool {
  ev0   : even(0)
  ev_ss : all n : UInt. if even(n) then even(n + 2)
}

theorem zero_is_even : even(0)
proof
  ev0
end

theorem two_is_even : even(2)
proof
  apply ev_ss[0] to ev0
end
