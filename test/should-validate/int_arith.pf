theorem T2: all x:Int. x + -3 + +4 = -1 + +2 + x
proof
  arbitrary x:Int
  equations
      x + (-3 + +4)
        = x + +1 by .
    ... = +1 + x by int_add_commute[x, +1]
    ... = -1 + +2 + x by .
end

