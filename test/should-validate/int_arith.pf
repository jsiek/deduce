import Int

assert +1 + +2 + +3 = +3 + +2 + +1
assert +1 + -2 + +3 = +3 + -2 + +1

theorem T1: all x:Int. x + +3 + +4 = +5 + +2 + x
proof
  arbitrary x:Int
  equations
      x + +3 + +4
        = x + +7 by .
    ... = +7 + x by int_add_commute[x, +7]
    ... = +5 + +2 + x by .
end

