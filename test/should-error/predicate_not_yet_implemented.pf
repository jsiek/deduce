// Phase 1 of `predicate` / `relation` adds the surface syntax and AST
// only. The semantics (rule validation, strict positivity, intro
// lemmas, induction principle) lands in a follow-up commit.

import UInt

predicate even : fn UInt -> bool {
  ev0 : even(0)
  ev_ss : all n : UInt. if even(n) then even(n + 2)
}
