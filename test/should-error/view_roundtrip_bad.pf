import UInt

fun uint_unview(v : UIntView) {
  switch v {
    case UIntZero { 0 }
    case UIntSucc(p) { 1 + p }
  }
}

postulate not_the_view_law:
  all v:UIntView. uint_unview(v) = uint_unview(v)

view UIntCons {
  source UInt
  target UIntView
  into uint_view
  out uint_unview
  roundtrip not_the_view_law
}
