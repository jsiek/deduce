public proc identity<T>(x: T, ghost witness: T) -> T
  requires x = x
  requires witness = witness
  reads x
  reads witness
  modifies x
  modifies witness
  decreases x
  decreases witness
  ensures result_self: result = result
  ensures x = x
{
  var a : T := x
  var b := witness
  ghost var c : T := x
  ghost var d := witness
  a := b
  if a = b {
    a := x
  } else {
    b := x
  }
  while a = b
    invariant a = a
    modifies a, b
    decreases x
  {
    a := b
  }
  assert a = a
  assume b = b
  return a
}

private proc no_return(x: bool)
  ensures x = x
{
}

opaque proc hidden()
{
}
