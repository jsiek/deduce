module BigO

import UInt

/*
  Elementary asymptotic notation for functions `UInt -> UInt`.

  The relation `f â‰² g` means that, after some threshold `n0`, `f` is
  bounded above by a constant multiple of `g`. The relation `f â‰ˆ g`
  is the induced two-sided equivalence.
*/

// Pointwise addition of cost functions.
fun operator + (f : fn UInt -> UInt, g : fn UInt -> UInt) {
  fun x:UInt {
    f(x) + g(x)
  }
}

// Pointwise multiplication of cost functions.
fun operator * (f : fn UInt -> UInt, g : fn UInt -> UInt) {
  fun x:UInt {
    f(x) * g(x)
  }
}

// Scale a cost function by a constant.
fun operator * (k : UInt, g : fn UInt -> UInt) {
  fun x:UInt {
    k * g(x)
  }
}

// Big-O preorder.
fun operator â‰² (f : fn UInt -> UInt, g : fn UInt -> UInt) {
  some n0 :UInt, c:UInt. all n:UInt. if n0 â‰¤ n then f(n) â‰¤ c * g(n)
}

// Asymptotic equivalence.
fun operator â‰ˆ (f : fn UInt -> UInt, g : fn UInt -> UInt) {
  (f â‰² g) and (g â‰² f)
}

fun log(f : fn UInt -> UInt) {
  fun x:UInt { log(f(x)) }
}


// Constant Time
fun O_1(n:UInt) { 1 }

// Logarithmic Time
fun O_log(n:UInt) { log(n) }

// Linear Time
fun O_n(n:UInt) { n }

// Quadratic Time
fun O_n2(n:UInt) { n * n }

theorem bigo_refl: all f : fn UInt -> UInt. f â‰² f
proof
  arbitrary f : fn UInt -> UInt
  expand operatorâ‰²
  choose 0, 1
  arbitrary n:UInt
  assume prem
  show f(n) â‰¤ 1 * f(n)
  uint_less_equal_refl
end

theorem bigo_trans: all f : fn UInt -> UInt, g : fn UInt -> UInt, h : fn UInt -> UInt.
  if f â‰² g and g â‰² h then f â‰² h
proof
  arbitrary f : fn UInt -> UInt, g : fn UInt -> UInt, h : fn UInt -> UInt
  assume prem
  have fg: f â‰² g by prem
  obtain n1, c1 where fg_all: all n:UInt. if n1 â‰¤ n then f(n) â‰¤ c1 * g(n)
    from expand operatorâ‰² in fg
  have gh: g â‰² h by prem
  obtain n2, c2 where gh_all: all n:UInt. if n2 â‰¤ n then g(n) â‰¤ c2 * h(n)
    from expand operatorâ‰² in gh
  expand operatorâ‰²
  choose n1+n2, c1*c2
  arbitrary n:UInt
  assume n12_n
  show f(n) â‰¤ (c1 * c2) * h(n)

  have n1_n: n1 â‰¤ n by {
    have n1_n12: n1 â‰¤ n1 + n2 by uint_less_equal_add
    apply uint_less_equal_trans to n1_n12, n12_n
  }
  have fg_n: f(n) â‰¤ c1 * g(n) by apply fg_all to n1_n
  
  have n2_n: n2 â‰¤ n by {
    have n2_n21: n2 â‰¤ n1 + n2 by { replace uint_add_commute uint_less_equal_add }
    apply uint_less_equal_trans to n2_n21, n12_n
  }
  have gh_n: g(n) â‰¤ c2 * h(n) by apply gh_all to n2_n

  have c1g_c12_h: c1 * g(n) â‰¤ c1 * c2 * h(n)
    by apply uint_mult_mono_le[c1, g(n), c2*h(n)] to gh_n
  
  conclude f(n) â‰¤ c1 * c2 * h(n)
    by apply uint_less_equal_trans to fg_n, c1g_c12_h
end

theorem bigo_add: all f: fn UInt->UInt. f + f â‰² f
proof
  arbitrary f: fn UInt->UInt
  expand operatorâ‰²
  choose 0, 2
  arbitrary n:UInt
  assume prem
  expand operator+
  show f(n) + f(n) â‰¤ 2 * f(n)
  replace uint_two_mult.
end

theorem bigo_const_mult: all f: fn UInt -> UInt, k:UInt.
  k * f â‰² f
proof
  arbitrary f: fn UInt -> UInt
  define P = fun c:UInt { c * f â‰² f }
  have base: P(0) by {
    expand P | operatorâ‰² | operator*.
  }
  have ind: all m:UInt. if P(m) then P(1 + m) by {
    arbitrary m:UInt
    expand P
    assume mf_f: m * f â‰² f 
    obtain n0, c where mf_f_all: all n:UInt. if n0 â‰¤ n then m * f(n) â‰¤ c * f(n)
      from expand operatorâ‰² | operator* in mf_f
    expand operatorâ‰²
    choose n0, 2*(1 + c)
    arbitrary n:UInt
    assume n0_n
    expand operator*
    replace uint_dist_mult_add_right | uint_dist_mult_add
    show f(n) + m * f(n) â‰¤ 2 * f(n) + 2 * c * f(n)
    
    have fn_cfn: f(n) â‰¤ 2 * f(n) by replace uint_two_mult uint_less_equal_add
    have mfn_2cfn: m * f(n) â‰¤ 2 * c * f(n) by {
      have IH: m * f(n) â‰¤ c * f(n) by apply mf_f_all[n] to n0_n
      have cfn_2cfn: c * f(n) â‰¤ 2 * c * f(n) by {
        apply uint_mult_mono_le2[1,c*f(n),2,c*f(n)] to .
      }
      apply uint_less_equal_trans to IH, cfn_2cfn
    }
    conclude f(n) + m * f(n) â‰¤ 2 * f(n) + 2 * c * f(n)
      by apply uint_add_mono_less_equal to fn_cfn, mfn_2cfn
  }
  expand P in apply uint_induction[P] to base, ind
end

theorem bigo_mult_mono:
  all f1: fn UInt->UInt, f2: fn UInt->UInt, g1: fn UInt->UInt, g2: fn UInt->UInt.
  if f1 â‰² g1 and f2 â‰² g2
  then f1 * f2 â‰² g1 * g2
proof
  arbitrary f1: fn UInt->UInt, f2: fn UInt->UInt, g1: fn UInt->UInt, g2: fn UInt->UInt
  assume prem
  expand operatorâ‰² | operator*
  have f1_g1: f1 â‰² g1 by prem
  obtain n1, c1 where f1_c1g1_all: all n:UInt. if n1 â‰¤ n then f1(n) â‰¤ c1 * g1(n)
    from expand operatorâ‰² in f1_g1
  have f2_g2: f2 â‰² g2 by prem
  obtain n2, c2 where f2_c2g2_all: all n:UInt. if n2 â‰¤ n then f2(n) â‰¤ c2 * g2(n)
    from expand operatorâ‰² in f2_g2
  choose n1 + n2, c1 * c2
  arbitrary n:UInt
  assume n12_n: n1 + n2 â‰¤ n
  show f1(n) * f2(n) â‰¤ c1 * c2 * g1(n) * g2(n)

  have n1_n: n1 â‰¤ n by {
    have n1_n12: n1 â‰¤ n1 + n2 by uint_less_equal_add
    apply uint_less_equal_trans to n1_n12, n12_n
  }
  have f1_c1g1: f1(n) â‰¤ c1 * g1(n)
    by apply f1_c1g1_all to n1_n
  
  have n2_n: n2 â‰¤ n by {
    have n2_n12: n2 â‰¤ n1 + n2 by { replace uint_add_commute uint_less_equal_add }
    apply uint_less_equal_trans to n2_n12, n12_n
  }
  have f2_c2g2: f2(n) â‰¤ c2 * g2(n)
    by apply f2_c2g2_all to n2_n
  
  have f12_c1g1_c2g2: f1(n) * f2(n) â‰¤ c1 * g1(n) * c2 * g2(n)
    by apply uint_mult_mono_le2[f1(n), f2(n)] to f1_c1g1, f2_c2g2

  conclude f1(n) * f2(n) â‰¤ c1 * c2 * g1(n) * g2(n)
    by replace uint_mult_commute[g1(n),c2] in f12_c1g1_c2g2
end

// Pointwise ordering of cost functions implies asymptotic ordering.
theorem bigo_pointwise_le: all f:fn UInt->UInt, g:fn UInt->UInt.
  if (all n:UInt. f(n) â‰¤ g(n)) then f â‰² g
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume H
  expand operatorâ‰²
  choose 0, 1
  arbitrary n:UInt
  assume _
  show f(n) â‰¤ 1 * g(n)
  H
end

// Each summand is bounded above by the sum.
theorem bigo_self_le_add: all f:fn UInt->UInt, g:fn UInt->UInt. f â‰² f + g
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  expand operatorâ‰² | operator+
  choose 0, 1
  arbitrary n:UInt
  assume _
  show f(n) â‰¤ 1 * (f(n) + g(n))
  uint_less_equal_add
end

theorem bigo_le_add_self: all f:fn UInt->UInt, g:fn UInt->UInt. g â‰² f + g
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  expand operatorâ‰² | operator+
  choose 0, 1
  arbitrary n:UInt
  assume _
  show g(n) â‰¤ 1 * (f(n) + g(n))
  uint_less_equal_add_left
end

// Asymptotic equivalence is reflexive, symmetric, and transitive.
theorem bigo_equiv_refl: all f:fn UInt->UInt. f â‰ˆ f
proof
  arbitrary f:fn UInt->UInt
  expand operatorâ‰ˆ
  have rf: f â‰² f by bigo_refl
  rf, rf
end

theorem bigo_equiv_sym: all f:fn UInt->UInt, g:fn UInt->UInt.
  if f â‰ˆ g then g â‰ˆ f
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume H
  have fg: f â‰² g by expand operatorâ‰ˆ in H
  have gf: g â‰² f by expand operatorâ‰ˆ in H
  expand operatorâ‰ˆ
  gf, fg
end

theorem bigo_equiv_trans:
  all f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt.
  if f â‰ˆ g and g â‰ˆ h then f â‰ˆ h
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt
  assume prem
  have fg: f â‰ˆ g by prem
  have gh: g â‰ˆ h by prem
  have f_g: f â‰² g by expand operatorâ‰ˆ in fg
  have g_f: g â‰² f by expand operatorâ‰ˆ in fg
  have g_h: g â‰² h by expand operatorâ‰ˆ in gh
  have h_g: h â‰² g by expand operatorâ‰ˆ in gh
  have fh: f â‰² h by apply bigo_trans to f_g, g_h
  have hf: h â‰² f by apply bigo_trans to h_g, g_f
  expand operatorâ‰ˆ
  fh, hf
end

// Additivity of â‰²: pointwise sum is monotone in both arguments.
theorem bigo_add_mono:
  all f1:fn UInt->UInt, f2:fn UInt->UInt, g1:fn UInt->UInt, g2:fn UInt->UInt.
  if f1 â‰² g1 and f2 â‰² g2 then f1 + f2 â‰² g1 + g2
proof
  arbitrary f1:fn UInt->UInt, f2:fn UInt->UInt, g1:fn UInt->UInt, g2:fn UInt->UInt
  assume prem
  have f1g1: f1 â‰² g1 by prem
  obtain n1, c1 where f1_g1_all: all n:UInt. if n1 â‰¤ n then f1(n) â‰¤ c1 * g1(n)
    from expand operatorâ‰² in f1g1
  have f2g2: f2 â‰² g2 by prem
  obtain n2, c2 where f2_g2_all: all n:UInt. if n2 â‰¤ n then f2(n) â‰¤ c2 * g2(n)
    from expand operatorâ‰² in f2g2
  expand operatorâ‰² | operator+
  choose n1 + n2, c1 + c2
  arbitrary n:UInt
  assume n12_n: n1 + n2 â‰¤ n
  show f1(n) + f2(n) â‰¤ (c1 + c2) * (g1(n) + g2(n))

  have n1_n12: n1 â‰¤ n1 + n2 by uint_less_equal_add
  have n1_n: n1 â‰¤ n by apply uint_less_equal_trans to n1_n12, n12_n
  have n2_n12: n2 â‰¤ n1 + n2 by uint_less_equal_add_left
  have n2_n: n2 â‰¤ n by apply uint_less_equal_trans to n2_n12, n12_n

  have f1_le: f1(n) â‰¤ c1 * g1(n) by apply f1_g1_all to n1_n
  have f2_le: f2(n) â‰¤ c2 * g2(n) by apply f2_g2_all to n2_n

  have c1_le: c1 â‰¤ c1 + c2 by uint_less_equal_add
  have c2_le: c2 â‰¤ c1 + c2 by uint_less_equal_add_left
  have g1_le: g1(n) â‰¤ g1(n) by .
  have g2_le: g2(n) â‰¤ g2(n) by .

  have step_c1: c1 * g1(n) â‰¤ (c1 + c2) * g1(n)
    by apply uint_mult_mono_le2 to c1_le, g1_le
  have step_c2: c2 * g2(n) â‰¤ (c1 + c2) * g2(n)
    by apply uint_mult_mono_le2 to c2_le, g2_le

  have f1_bigger: f1(n) â‰¤ (c1 + c2) * g1(n)
    by apply uint_less_equal_trans to f1_le, step_c1
  have f2_bigger: f2(n) â‰¤ (c1 + c2) * g2(n)
    by apply uint_less_equal_trans to f2_le, step_c2

  have step_add: f1(n) + f2(n) â‰¤ (c1 + c2) * g1(n) + (c1 + c2) * g2(n)
    by apply uint_add_mono_less_equal to f1_bigger, f2_bigger

  conclude f1(n) + f2(n) â‰¤ (c1 + c2) * (g1(n) + g2(n))
    by replace uint_dist_mult_add
       step_add
end

// Pointwise addition is commutative up to â‰ˆ.
theorem bigo_add_commute: all f:fn UInt->UInt, g:fn UInt->UInt.
  f + g â‰ˆ g + f
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  expand operatorâ‰ˆ
  have A: f + g â‰² g + f by {
    expand operatorâ‰² | operator+
    choose 0, 1
    arbitrary n:UInt
    assume _
    show f(n) + g(n) â‰¤ 1 * (g(n) + f(n))
    replace uint_add_commute[g(n), f(n)].
  }
  have B: g + f â‰² f + g by {
    expand operatorâ‰² | operator+
    choose 0, 1
    arbitrary n:UInt
    assume _
    show g(n) + f(n) â‰¤ 1 * (f(n) + g(n))
    replace uint_add_commute[f(n), g(n)].
  }
  A, B
end

// Pointwise multiplication is commutative up to â‰ˆ.
theorem bigo_mult_commute: all f:fn UInt->UInt, g:fn UInt->UInt.
  f * g â‰ˆ g * f
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  expand operatorâ‰ˆ
  have A: f * g â‰² g * f by {
    expand operatorâ‰² | operator*
    choose 0, 1
    arbitrary n:UInt
    assume _
    show f(n) * g(n) â‰¤ 1 * (g(n) * f(n))
    replace uint_mult_commute[g(n), f(n)].
  }
  have B: g * f â‰² f * g by {
    expand operatorâ‰² | operator*
    choose 0, 1
    arbitrary n:UInt
    assume _
    show g(n) * f(n) â‰¤ 1 * (f(n) * g(n))
    replace uint_mult_commute[f(n), g(n)].
  }
  A, B
end

// Sum absorption: a dominated summand can be dropped.
theorem bigo_add_absorb: all f:fn UInt->UInt, g:fn UInt->UInt.
  if g â‰² f then f + g â‰² f
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume g_f: g â‰² f
  have f_f: f â‰² f by bigo_refl
  have step: f + g â‰² f + f
    by apply bigo_add_mono to f_f, g_f
  have ff: f + f â‰² f by bigo_add
  apply bigo_trans to step, ff
end

// Multiplying by a constant k â‰¥ 1 only increases asymptotic cost.
theorem bigo_le_const_mult: all f:fn UInt->UInt, k:UInt.
  if 1 â‰¤ k then f â‰² k * f
proof
  arbitrary f:fn UInt->UInt, k:UInt
  assume k_pos: 1 â‰¤ k
  expand operatorâ‰² | operator*
  choose 0, 1
  arbitrary n:UInt
  assume _
  show f(n) â‰¤ 1 * (k * f(n))
  have fn_fn: f(n) â‰¤ f(n) by .
  have step: 1 * f(n) â‰¤ k * f(n)
    by apply uint_mult_mono_le2 to k_pos, fn_fn
  step
end

// Any constant function is O(1).
theorem bigo_const_func_le_O_1: all c:UInt.
  (fun n:UInt { c }) â‰² O_1
proof
  arbitrary c:UInt
  expand operatorâ‰² | O_1
  choose 0, c
  arbitrary n:UInt
  assume _
  show c â‰¤ c * 1
  .
end

theorem constant_le_log: O_1 â‰² O_log
proof
  expand operatorâ‰² | O_1 | O_log
  choose 2, 1
  arbitrary n:UInt
  assume two_n
  apply uint_log_greater_one to two_n
end

theorem log_le_linear: O_log â‰² O_n
proof
  expand operatorâ‰² | O_log | O_n
  choose 0, 1
  arbitrary n:UInt
  assume _
  uint_logn_le_n
end

theorem linear_le_quadratic: O_n â‰² O_n2
proof
  expand operatorâ‰² | O_n | O_n2
  choose 1, 1
  arbitrary n:UInt
  assume pos
  have n_n: n â‰¤ n by .
  conclude 1 * n â‰¤ n * n by apply uint_mult_mono_le2 to pos, n_n
end

fun O_2n(n:UInt) { 2*n }

theorem O_n_eq_O_2n: O_n â‰ˆ O_2n
proof
  expand operatorâ‰ˆ
  have A: O_n â‰² O_2n by {
    expand operatorâ‰²
    choose 0, 1
    arbitrary n:UInt
    assume _
    expand O_n | O_2n
    replace uint_two_mult
    uint_less_equal_add
  }
  have B: O_2n â‰² O_n by {
    expand operatorâ‰²
    choose 0, 2
    arbitrary n:UInt
    assume prem
    expand O_n | O_2n.
  }
  A, B
end

fun positive(f : fn UInt -> UInt) {
  all n:UInt. 0 < f(n)
}

theorem log_product_less_equal_sum:
  all f:fn UInt -> UInt, g:fn UInt -> UInt.
  if (all n:UInt. 1 < f(n)) and (all n:UInt. 1 < g(n))
  then log(f * g) â‰² log(f) + log(g)
proof
  arbitrary f:fn UInt -> UInt, g:fn UInt -> UInt
  assume fg_gt_1
  expand operatorâ‰² | operator+ | operator* | log
  choose 0, 2
  arbitrary n:UInt
  assume _
  have A: log(f(n) * g(n)) â‰¤ 1 + log(f(n)) + log(g(n)) by uint_log_mult_le_log_add
  have B: 1 + log(f(n)) + log(g(n)) â‰¤ 2 * (log(f(n)) + log(g(n))) by {
    have log_fg_pos: 0 < log(f(n)) + log(g(n)) by {
      have log_f_pos: 0 < log(f(n)) by apply uint_log_pos[f(n)] to fg_gt_1
      have log_g_pos: 0 < log(g(n)) by apply uint_log_pos[g(n)] to fg_gt_1
      apply uint_add_mono_less[0, 0, log(f(n)), log(g(n))] to log_f_pos, log_g_pos
    }
    replace uint_two_mult
    apply uint_add_one_le_double to log_fg_pos
  }
  apply uint_less_equal_trans to A, B
end

theorem log_sum_less_equal_product:
  all f:fn UInt -> UInt, g:fn UInt -> UInt.
  if (all n:UInt. 0 < f(n)) and (all n:UInt. 0 < g(n))
  then log(f) + log(g) â‰² log(f * g)
proof
  arbitrary f:fn UInt -> UInt, g:fn UInt -> UInt
  assume fg_pos
  expand operatorâ‰² | operator+ | operator* | log
  choose 0, 1
  arbitrary n:UInt
  assume _
  have f_pos: 0 < f(n) by fg_pos
  have g_pos: 0 < g(n) by fg_pos
  apply uint_log_add_le_log_mult to f_pos, g_pos
end

theorem log_product_equiv_sum:
  all f:fn UInt -> UInt, g:fn UInt -> UInt.
  if (all n:UInt. 1 < f(n)) and (all n:UInt. 1 < g(n))
  then log(f * g) â‰ˆ log(f) + log(g)
proof
  arbitrary f:fn UInt -> UInt, g:fn UInt -> UInt
  assume fg_gt_1
  expand operatorâ‰ˆ
  have A: log(f * g) â‰² log(f) + log(g) by apply log_product_less_equal_sum[f,g] to fg_gt_1
  have f_pos: all n:UInt. 0 < f(n) by {
    arbitrary n:UInt
    have one_lt_f: 1 < f(n) by fg_gt_1
    have zero_lt_one: (0:UInt) < 1 by .
    apply uint_less_trans to zero_lt_one, one_lt_f
  }
  have g_pos: all n:UInt. 0 < g(n) by {
    arbitrary n:UInt
    have one_lt_g: 1 < g(n) by fg_gt_1
    have zero_lt_one: (0:UInt) < 1 by .
    apply uint_less_trans to zero_lt_one, one_lt_g
  }
  have B: log(f) + log(g) â‰² log(f * g)
    by apply log_sum_less_equal_product[f,g] to f_pos, g_pos
  A, B
end

// Pointwise equality lifts to asymptotic equivalence.
theorem bigo_pointwise_eq: all f:fn UInt->UInt, g:fn UInt->UInt.
  if (all n:UInt. f(n) = g(n)) then f â‰ˆ g
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume H
  expand operatorâ‰ˆ
  have fg: f â‰² g by {
    expand operatorâ‰²
    choose 0, 1
    arbitrary n:UInt
    assume _
    show f(n) â‰¤ 1 * g(n)
    have eq: f(n) = g(n) by H
    replace eq.
  }
  have gf: g â‰² f by {
    expand operatorâ‰²
    choose 0, 1
    arbitrary n:UInt
    assume _
    show g(n) â‰¤ 1 * f(n)
    have eq: f(n) = g(n) by H
    replace symmetric eq.
  }
  fg, gf
end

// Pointwise addition is associative up to â‰ˆ.
theorem bigo_add_assoc: all f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt.
  (f + g) + h â‰ˆ f + (g + h)
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt
  have pointwise: all m:UInt. ((f + g) + h)(m) = (f + (g + h))(m) by {
    arbitrary m:UInt
    expand operator+.
  }
  apply bigo_pointwise_eq[(f + g) + h, f + (g + h)] to pointwise
end

// Pointwise multiplication is associative up to â‰ˆ.
theorem bigo_mult_assoc: all f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt.
  (f * g) * h â‰ˆ f * (g * h)
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt
  have pointwise: all m:UInt. ((f * g) * h)(m) = (f * (g * h))(m) by {
    arbitrary m:UInt
    expand operator*.
  }
  apply bigo_pointwise_eq[(f * g) * h, f * (g * h)] to pointwise
end

// The zero cost function is a right identity for + up to â‰ˆ.
theorem bigo_add_zero: all f:fn UInt->UInt.
  f + (fun n:UInt { 0 }) â‰ˆ f
proof
  arbitrary f:fn UInt->UInt
  have pointwise: all m:UInt. (f + (fun n:UInt { 0 }))(m) = f(m) by {
    arbitrary m:UInt
    expand operator+.
  }
  apply bigo_pointwise_eq[f + (fun n:UInt { 0 }), f] to pointwise
end

// The constant-1 function is a right identity for * up to â‰ˆ.
theorem bigo_mult_one_func: all f:fn UInt->UInt.
  f * (fun n:UInt { 1 }) â‰ˆ f
proof
  arbitrary f:fn UInt->UInt
  have pointwise: all m:UInt. (f * (fun n:UInt { 1 }))(m) = f(m) by {
    arbitrary m:UInt
    expand operator*.
  }
  apply bigo_pointwise_eq[f * (fun n:UInt { 1 }), f] to pointwise
end

// Pointwise multiplication distributes over pointwise addition up to â‰ˆ.
theorem bigo_dist: all f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt.
  f * (g + h) â‰ˆ f * g + f * h
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt
  have pointwise: all m:UInt. (f * (g + h))(m) = (f * g + f * h)(m) by {
    arbitrary m:UInt
    expand operator+ | operator*
    show f(m) * (g(m) + h(m)) = f(m) * g(m) + f(m) * h(m)
    uint_dist_mult_add
  }
  apply bigo_pointwise_eq[f * (g + h), f * g + f * h] to pointwise
end

// Two-sided sum absorption: a dominated summand can be dropped under â‰ˆ.
theorem bigo_add_dominated_absorb_equiv: all f:fn UInt->UInt, g:fn UInt->UInt.
  if g â‰² f then f + g â‰ˆ f
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume g_f: g â‰² f
  expand operatorâ‰ˆ
  have A: f + g â‰² f by apply bigo_add_absorb to g_f
  have B: f â‰² f + g by bigo_self_le_add
  A, B
end

// A positive constant factor drops out of â‰ˆ.
theorem bigo_const_mult_equiv: all f:fn UInt->UInt, k:UInt.
  if 0 < k then k * f â‰ˆ f
proof
  arbitrary f:fn UInt->UInt, k:UInt
  assume k_pos: 0 < k
  expand operatorâ‰ˆ
  have A: k * f â‰² f by bigo_const_mult
  have k_ge_1: 1 â‰¤ k by apply uint_pos_implies_one_le to k_pos
  have B: f â‰² k * f by apply bigo_le_const_mult[f, k] to k_ge_1
  A, B
end

// Pointwise maximum of cost functions.
fun max (f : fn UInt -> UInt, g : fn UInt -> UInt) {
  fun n:UInt { max(f(n), g(n)) }
}

// The pointwise max is bounded above by the pointwise sum.
theorem bigo_max_le_add: all f:fn UInt->UInt, g:fn UInt->UInt.
  max(f, g) â‰² f + g
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  expand operatorâ‰² | operator+ | max
  choose 0, 1
  arbitrary n:UInt
  assume _
  show max(f(n), g(n)) â‰¤ 1 * (f(n) + g(n))
  have f_le: f(n) â‰¤ f(n) + g(n) by uint_less_equal_add
  have g_le: g(n) â‰¤ f(n) + g(n) by uint_less_equal_add_left
  apply uint_max_less_equal to f_le, g_le
end

// The pointwise sum is bounded by a constant multiple of the pointwise max.
theorem bigo_add_le_max: all f:fn UInt->UInt, g:fn UInt->UInt.
  f + g â‰² max(f, g)
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  expand operatorâ‰² | operator+ | max
  choose 0, 2
  arbitrary n:UInt
  assume _
  show f(n) + g(n) â‰¤ 2 * max(f(n), g(n))
  have f_le: f(n) â‰¤ max(f(n), g(n)) by uint_max_greater_left
  have g_le: g(n) â‰¤ max(f(n), g(n)) by uint_max_greater_right
  have sum_le: f(n) + g(n) â‰¤ max(f(n), g(n)) + max(f(n), g(n))
    by apply uint_add_mono_less_equal to f_le, g_le
  replace uint_two_mult[max(f(n), g(n))]
  sum_le
end

// Big-Omega: `bigo_omega(f, g)` means `f` asymptotically dominates `g`
// â€” equivalently, `g â‰² f`. Big-Omega is the dual of the `â‰²` (Big-O) preorder.
fun bigo_omega(f : fn UInt -> UInt, g : fn UInt -> UInt) {
  g â‰² f
}

// Big-Omega is reflexive.
theorem bigo_omega_refl: all f:fn UInt->UInt. bigo_omega(f, f)
proof
  arbitrary f:fn UInt->UInt
  expand bigo_omega
  bigo_refl
end

// Big-Omega is transitive.
theorem bigo_omega_trans:
  all f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt.
  if bigo_omega(f, g) and bigo_omega(g, h) then bigo_omega(f, h)
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt, h:fn UInt->UInt
  assume prem
  have gf: g â‰² f by expand bigo_omega in prem
  have hg: h â‰² g by expand bigo_omega in prem
  expand bigo_omega
  apply bigo_trans to hg, gf
end

// Asymptotic equivalence is exactly Big-Theta: `f â‰ˆ g` iff `f` is both
// Big-O and Big-Omega of `g`.
theorem bigo_equiv_iff_theta: all f:fn UInt->UInt, g:fn UInt->UInt.
  f â‰ˆ g â‡” (f â‰² g and bigo_omega(f, g))
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  have fwd: if f â‰ˆ g then (f â‰² g and bigo_omega(f, g)) by {
    assume H
    have fg: f â‰² g by expand operatorâ‰ˆ in H
    have gf: g â‰² f by expand operatorâ‰ˆ in H
    have go: bigo_omega(f, g) by { expand bigo_omega gf }
    fg, go
  }
  have bkwd: if (f â‰² g and bigo_omega(f, g)) then f â‰ˆ g by {
    assume H
    have fg: f â‰² g by H
    have gf: g â‰² f by expand bigo_omega in H
    expand operatorâ‰ˆ
    fg, gf
  }
  fwd, bkwd
end

// Little-o: `bigo_little_o(f, g)` recasts the standard Îµ-formulation
// `lim f/g = 0` to the `UInt` setting. As `Îµ` shrinks toward `0`, its
// reciprocal `c = 1/Îµ` grows without bound, so the condition
// `f(n) < Îµ * g(n)` becomes `c * f(n) < g(n)` â€” eventually true for every
// positive `UInt` constant `c`. Spelled as a named function rather than an
// operator because no `â‰ª` token is wired into the grammar.
fun bigo_little_o(f : fn UInt -> UInt, g : fn UInt -> UInt) {
  all c:UInt. if 0 < c then some n0:UInt. all n:UInt. if n0 â‰¤ n then c * f(n) < g(n)
}

// Little-omega: the strict cousin of Big-Omega and the dual of little-o.
// `bigo_little_omega(f, g)` says `f` strictly dominates `g`, i.e. little-o
// the other way round.
fun bigo_little_omega(f : fn UInt -> UInt, g : fn UInt -> UInt) {
  bigo_little_o(g, f)
}

// Little-o implies Big-O: strict eventual domination is stronger than
// constant-factor eventual domination.
theorem bigo_little_implies_big: all f:fn UInt->UInt, g:fn UInt->UInt.
  if bigo_little_o(f, g) then f â‰² g
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume H: bigo_little_o(f, g)
  have one_pos: (0:UInt) < 1 by .
  have step1: some n0:UInt. all n:UInt. if n0 â‰¤ n then 1 * f(n) < g(n)
    by apply (expand bigo_little_o in H)[1] to one_pos
  obtain n0 where step: all n:UInt. if n0 â‰¤ n then 1 * f(n) < g(n) from step1
  expand operatorâ‰²
  choose n0, 1
  arbitrary n:UInt
  assume n0_n: n0 â‰¤ n
  show f(n) â‰¤ 1 * g(n)
  have lt: f(n) < g(n) by apply step to n0_n
  apply uint_less_implies_less_equal to lt
end

// Little-o is irreflexive: no function strictly dominates itself.
// Instantiating the `c = 1` case at `n = n0` would force `f(n0) < f(n0)`.
theorem bigo_little_irrefl: all f:fn UInt->UInt. not bigo_little_o(f, f)
proof
  arbitrary f:fn UInt->UInt
  assume H: bigo_little_o(f, f)
  have one_pos: (0:UInt) < 1 by .
  have step1: some n0:UInt. all n:UInt. if n0 â‰¤ n then 1 * f(n) < f(n)
    by apply (expand bigo_little_o in H)[1] to one_pos
  obtain n0 where step: all n:UInt. if n0 â‰¤ n then 1 * f(n) < f(n) from step1
  have n0_n0: n0 â‰¤ n0 by .
  have lt: f(n0) < f(n0) by apply step to n0_n0
  apply uint_less_irreflexive to lt
end

// Little-omega unfolds to a swapped little-o.
theorem bigo_little_omega_swap: all f:fn UInt->UInt, g:fn UInt->UInt.
  if bigo_little_omega(f, g) then bigo_little_o(g, f)
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume H
  expand bigo_little_omega in H
end

// Little-omega is irreflexive, by symmetry with little-o.
theorem bigo_little_omega_irrefl: all f:fn UInt->UInt. not bigo_little_omega(f, f)
proof
  arbitrary f:fn UInt->UInt
  assume H: bigo_little_omega(f, f)
  have ff: bigo_little_o(f, f) by expand bigo_little_omega in H
  apply bigo_little_irrefl to ff
end

// Little-omega implies Big-Omega.
theorem bigo_little_omega_implies_big_omega: all f:fn UInt->UInt, g:fn UInt->UInt.
  if bigo_little_omega(f, g) then bigo_omega(f, g)
proof
  arbitrary f:fn UInt->UInt, g:fn UInt->UInt
  assume H: bigo_little_omega(f, g)
  have gf: bigo_little_o(g, f) by expand bigo_little_omega in H
  have gf_big: g â‰² f by apply bigo_little_implies_big to gf
  expand bigo_omega
  gf_big
end

// Linearithmic time: n * log(n).
fun O_n_log_n(n:UInt) { n * log(n) }

// Cubic time.
fun O_n3(n:UInt) { n * n * n }

// Exponential time: 2^n.
fun O_2pow_n(n:UInt) { 2 ^ n }

// Linear is bounded by linearithmic: for n â‰¥ 2, log(n) â‰¥ 1, so
// n â‰¤ n * log(n).
theorem bigo_linear_le_n_log_n: O_n â‰² O_n_log_n
proof
  expand operatorâ‰² | O_n | O_n_log_n
  choose 2, 1
  arbitrary n:UInt
  assume two_n: 2 â‰¤ n
  show n â‰¤ 1 * (n * log(n))
  have one_log: 1 â‰¤ log(n) by apply uint_log_greater_one to two_n
  apply uint_mult_mono_le[n] to one_log
end

// Linearithmic is bounded by quadratic: log(n) â‰¤ n, so n * log(n) â‰¤ n * n.
theorem bigo_n_log_n_le_quadratic: O_n_log_n â‰² O_n2
proof
  expand operatorâ‰² | O_n_log_n | O_n2
  choose 0, 1
  arbitrary n:UInt
  assume _
  show n * log(n) â‰¤ 1 * (n * n)
  have logn_n: log(n) â‰¤ n by uint_logn_le_n
  have n_n: n â‰¤ n by .
  conclude n * log(n) â‰¤ 1 * (n * n) by apply uint_mult_mono_le2 to n_n, logn_n
end

// Quadratic is bounded by cubic: for n â‰¥ 1, n * n â‰¤ n * n * n.
theorem bigo_quadratic_le_cubic: O_n2 â‰² O_n3
proof
  expand operatorâ‰² | O_n2 | O_n3
  choose 1, 1
  arbitrary n:UInt
  assume one_n: 1 â‰¤ n
  show n * n â‰¤ 1 * (n * n * n)
  apply uint_mult_mono_le[n * n] to one_n
end

// Linear is bounded by exponential: for n â‰¥ 1, n < 2^(1+log(n)) â‰¤ 2^(1+n) = 2 * 2^n.
theorem bigo_linear_le_2pow_n: O_n â‰² O_2pow_n
proof
  expand operatorâ‰² | O_n | O_2pow_n
  choose 1, 2
  arbitrary n:UInt
  assume one_n: 1 â‰¤ n
  show n â‰¤ 2 * 2^n
  have n_pos: 0 < n by replace uint_less_is_less_equal[0, n] one_n
  have lt: n < 2^(1 + log(n)) by apply less_pow_log to n_pos
  have logn_n: log(n) â‰¤ n by uint_logn_le_n
  have one_le: (1:UInt) â‰¤ 1 by .
  have step: 1 + log(n) â‰¤ 1 + n by apply uint_add_mono_less_equal to one_le, logn_n
  have one_le_two: (1:UInt) â‰¤ 2 by .
  have pow_step: 2^(1 + log(n)) â‰¤ 2^(1 + n)
    by apply (apply uint_pow_le_mono_r[1 + n, 2, 1 + log(n)] to one_le_two) to step
  have lt_le: n < 2^(1 + n) by {
    have or_eq: 2^(1 + log(n)) < 2^(1 + n) or 2^(1 + log(n)) = 2^(1 + n) by expand operatorâ‰¤ in pow_step
    cases or_eq
    case lt_case { apply uint_less_trans to lt, lt_case }
    case eq_case { replace eq_case in lt }
  }
  have expand_pow: 2^(1 + n) = 2 * 2^n by uint_pow_add_r[2, 1, n]
  have lt_le2: n < 2 * 2^n by replace expand_pow in lt_le
  apply uint_less_implies_less_equal to lt_le2
end

// Polynomial monotonicity in the exponent. For n â‰¥ 1, n^a â‰¤ n^b when a â‰¤ b.
// The threshold n0 = 1 is enough: 0^a is 0 (when a > 0) or 1 (when a = 0),
// so the n = 0 corner is excluded here for simplicity.
theorem bigo_pow_mono: all a:UInt, b:UInt.
  if a â‰¤ b then (fun n:UInt { n^a }) â‰² (fun n:UInt { n^b })
proof
  arbitrary a:UInt, b:UInt
  assume a_le_b: a â‰¤ b
  expand operatorâ‰²
  choose 1, 1
  arbitrary n:UInt
  assume one_n: 1 â‰¤ n
  show n^a â‰¤ 1 * n^b
  apply (apply uint_pow_le_mono_r[b, n, a] to one_n) to a_le_b
end

// Pointwise: `log(f)(n) = log(f(n)) â‰¤ f(n)` by `uint_logn_le_n`.
// Hence `log(f) â‰² f` for any cost function `f`.
theorem bigo_log_le_self: all f:fn UInt->UInt. log(f) â‰² f
proof
  arbitrary f:fn UInt->UInt
  expand operatorâ‰² | log
  choose 0, 1
  arbitrary n:UInt
  assume _
  show log(f(n)) â‰¤ 1 * f(n)
  uint_logn_le_n
end

// Log of a constant function is bounded: `log(O_1) â‰² O_1`.
// Instance of `bigo_log_le_self` at `f = O_1`.
theorem bigo_log_const: log(O_1) â‰² O_1
proof
  bigo_log_le_self[O_1]
end

// Iterated log is bounded by log: `log(O_log) â‰² O_log`.
// Instance of `bigo_log_le_self` at `f = O_log`; concretely
// `log(log(n)) â‰¤ log(n)` for every `n`, which is the
// `n_log_log(n) â‰¤ log(n)` step in the `O(n log log n)` discussion.
theorem bigo_log_log: log(O_log) â‰² O_log
proof
  bigo_log_le_self[O_log]
end

// Polynomial-vs-exponential domination, base case k = 2: n*n â‰¤ 2^n for n â‰¥ 4.
// Proven by k-induction starting at 4. The inductive step uses the polynomial
// slack 1 + 2m â‰¤ m*m (via 1 + 2m â‰¤ 4m â‰¤ m*m, both valid for m â‰¥ 4) to bound
// (1+m)*(1+m) = 1 + 2m + m*m â‰¤ 2 * m*m, then folds the IH m*m â‰¤ 2^m through a
// factor of 2 to land on 2^(1+m).
lemma uint_quad_le_2pow: all n:UInt. if 4 â‰¤ n then n * n â‰¤ 2 ^ n
proof
  define P = fun n:UInt { n * n â‰¤ 2 ^ n }
  have base: P(4) by {
    expand P
    show 4 * 4 â‰¤ 2 ^ 4
    .
  }
  have ind: all m:UInt. if 4 â‰¤ m and P(m) then P(1 + m) by {
    arbitrary m:UInt
    assume prem
    have m_ge_4: 4 â‰¤ m by prem
    have IH: m * m â‰¤ 2 ^ m by expand P in prem
    expand P
    show (1 + m) * (1 + m) â‰¤ 2 ^ (1 + m)

    have expand_sq: (1 + m) * (1 + m) = 1 + 2 * m + m * m by {
      replace uint_dist_mult_add_right[1, m, 1+m]
           | uint_dist_mult_add[m, 1, m]
           | uint_two_mult[m].
    }

    have m_ge_1: 1 â‰¤ m by {
      have one_le_four: (1:UInt) â‰¤ 4 by .
      apply uint_less_equal_trans to one_le_four, m_ge_4
    }

    have m_le_m: m â‰¤ m by .
    have four_m_le_m_m: 4 * m â‰¤ m * m
      by apply uint_mult_mono_le2 to m_ge_4, m_le_m

    have one_le_2m: (1:UInt) â‰¤ 2 * m by {
      have one_le_two: (1:UInt) â‰¤ 2 by .
      have two_le_2m: (2:UInt) â‰¤ 2 * m by apply uint_mult_mono_le[2] to m_ge_1
      apply uint_less_equal_trans to one_le_two, two_le_2m
    }

    have four_m_eq: (4:UInt) * m = 2 * m + 2 * m
      by uint_dist_mult_add_right[2, 2, m]

    have step_2m_le_4m: 1 + 2 * m â‰¤ 4 * m by {
      replace four_m_eq
      have two_m_le: 2 * m â‰¤ 2 * m by .
      apply uint_add_mono_less_equal to one_le_2m, two_m_le
    }

    have slack: 1 + 2 * m â‰¤ m * m
      by apply uint_less_equal_trans to step_2m_le_4m, four_m_le_m_m

    have step_sum: (1 + 2 * m) + m * m â‰¤ m * m + m * m by {
      have mm_le_mm: m * m â‰¤ m * m by .
      apply uint_add_mono_less_equal to slack, mm_le_mm
    }

    have two_mm_eq: m * m + m * m = 2 * (m * m)
      by symmetric uint_two_mult[m * m]
    have step_2mm: (1 + 2 * m) + m * m â‰¤ 2 * (m * m)
      by replace two_mm_eq in step_sum

    have step_lhs_2mm: (1 + m) * (1 + m) â‰¤ 2 * (m * m) by {
      replace expand_sq
      step_2mm
    }

    have step_two_pow_m: 2 * (m * m) â‰¤ 2 * 2 ^ m
      by apply uint_mult_mono_le[2] to IH

    have step_chain: (1 + m) * (1 + m) â‰¤ 2 * 2 ^ m
      by apply uint_less_equal_trans to step_lhs_2mm, step_two_pow_m

    have pow_step: 2 ^ (1 + m) = 2 * 2 ^ m by uint_pow_add_r[2, 1, m]

    replace pow_step
    step_chain
  }
  expand P in apply uint_k_induction[P, 4] to base, ind
end

// Quadratic is bounded by exponential: O(n^2) â‰² O(2^n). Threshold n0 = 4,
// constant c = 1 (uint_quad_le_2pow gives the pointwise inequality directly).
theorem bigo_quadratic_le_2pow_n: O_n2 â‰² O_2pow_n
proof
  expand operatorâ‰² | O_n2 | O_2pow_n
  choose 4, 1
  arbitrary n:UInt
  assume four_n: 4 â‰¤ n
  show n * n â‰¤ 1 * 2 ^ n
  apply uint_quad_le_2pow to four_n
end

// Polynomial-vs-exponential domination, k = 3: n*n*n â‰¤ 2^n for n â‰¥ 10.
// Proven by k-induction starting at 10 (10^3 = 1000 â‰¤ 1024 = 2^10). The
// inductive step expands (1+m)*(1+m)*(1+m) to 1 + 3m + 3*(m*m) + m*m*m,
// then uses the polynomial slack 1 + 3m + 3*(m*m) â‰¤ m*m*m to bound the
// expansion by 2*(m*m*m) and folds the IH through a factor of 2 to land
// on 2^(1+m). The slack chain is 1 + 3m â‰¤ 4m â‰¤ m*m and m*m + 3*(m*m) =
// 4*(m*m) â‰¤ m*(m*m) = m*m*m, both valid for m â‰¥ 4.
lemma uint_cube_le_2pow: all n:UInt. if 10 â‰¤ n then n * n * n â‰¤ 2 ^ n
proof
  define P = fun n:UInt { n * n * n â‰¤ 2 ^ n }
  have base: P(10) by {
    expand P
    show 10 * 10 * 10 â‰¤ 2 ^ 10
    .
  }
  have ind: all m:UInt. if 10 â‰¤ m and P(m) then P(1 + m) by {
    arbitrary m:UInt
    assume prem
    have m_ge_10: 10 â‰¤ m by prem
    have IH: m * m * m â‰¤ 2 ^ m by expand P in prem
    expand P
    show (1 + m) * (1 + m) * (1 + m) â‰¤ 2 ^ (1 + m)

    have m_ge_4: 4 â‰¤ m by {
      have four_le_ten: (4:UInt) â‰¤ 10 by .
      apply uint_less_equal_trans to four_le_ten, m_ge_10
    }
    have m_ge_1: 1 â‰¤ m by {
      have one_le_ten: (1:UInt) â‰¤ 10 by .
      apply uint_less_equal_trans to one_le_ten, m_ge_10
    }

    have expand_sq: (1 + m) * (1 + m) = 1 + 2 * m + m * m by {
      replace uint_dist_mult_add_right[1, m, 1+m]
           | uint_dist_mult_add[m, 1, m]
           | uint_two_mult[m].
    }

    // (1+m)^3 = ((1+m)*(1+m))*(1+m) = (1 + 2m + m^2)*(1+m)
    //         = 1 + m + 2m + 2m^2 + m^2 + m^3
    //         = 1 + 3m + 3*(m^2) + m^3
    have expand_cube:
      (1 + m) * (1 + m) * (1 + m) = 1 + 3 * m + 3 * (m * m) + m * m * m
    by {
      replace expand_sq
      show (1 + 2*m + m*m) * (1 + m) = 1 + 3*m + 3*(m*m) + m*m*m
      have combine_m: 2 * m + m = 3 * m
        by symmetric uint_dist_mult_add_right[2, 1, m]
      have combine_m2: 2 * (m * m) + m * m = 3 * (m * m)
        by symmetric uint_dist_mult_add_right[2, 1, m * m]
      replace uint_dist_mult_add_right[1 + 2*m, m*m, 1+m]
           | uint_dist_mult_add[1 + 2*m, 1, m]
           | uint_dist_mult_add[m*m, 1, m]
           | uint_dist_mult_add_right[1, 2*m, m]
           | combine_m
           | combine_m2.
    }

    // 1 + 3m â‰¤ m*m via 1 + 3m â‰¤ 4m â‰¤ m*m (using m â‰¥ 4).
    have four_eq: (4:UInt) * m = m + 3 * m by uint_dist_mult_add_right[1, 3, m]
    have one_3m_le_4m: 1 + 3 * m â‰¤ 4 * m by {
      replace four_eq
      have step: 3 * m â‰¤ 3 * m by .
      apply uint_add_mono_less_equal to m_ge_1, step
    }
    have m_le_m: m â‰¤ m by .
    have four_m_le_mm: 4 * m â‰¤ m * m
      by apply uint_mult_mono_le2 to m_ge_4, m_le_m
    have one_3m_le_mm: 1 + 3 * m â‰¤ m * m
      by apply uint_less_equal_trans to one_3m_le_4m, four_m_le_mm

    // (1 + 3m) + 3*(m*m) â‰¤ m*m + 3*(m*m) = 4*(m*m) â‰¤ m*(m*m) = m*m*m.
    have three_mm_le: 3 * (m * m) â‰¤ 3 * (m * m) by .
    have step_sum: (1 + 3 * m) + 3 * (m * m) â‰¤ m * m + 3 * (m * m)
      by apply uint_add_mono_less_equal to one_3m_le_mm, three_mm_le

    have four_mm_eq: m * m + 3 * (m * m) = 4 * (m * m) by {
      have eq: (4:UInt) * (m * m) = 1 * (m * m) + 3 * (m * m)
        by uint_dist_mult_add_right[1, 3, m * m]
      replace eq.
    }

    have mm_le_mm: m * m â‰¤ m * m by .
    have four_mm_le_mmm: 4 * (m * m) â‰¤ m * (m * m)
      by apply uint_mult_mono_le2 to m_ge_4, mm_le_mm
    have mmm_assoc: m * (m * m) = m * m * m by symmetric uint_mult_assoc[m, m, m]
    have four_mm_le: 4 * (m * m) â‰¤ m * m * m by replace mmm_assoc in four_mm_le_mmm

    have slack: (1 + 3 * m) + 3 * (m * m) â‰¤ m * m * m by {
      have step1: (1 + 3 * m) + 3 * (m * m) â‰¤ 4 * (m * m)
        by replace four_mm_eq in step_sum
      apply uint_less_equal_trans to step1, four_mm_le
    }

    // Add m*m*m to both sides of the slack: (1 + 3m + 3m^2) + m^3 â‰¤ 2*m^3.
    have mmm_le_mmm: m * m * m â‰¤ m * m * m by .
    have step_combined: ((1 + 3 * m) + 3 * (m * m)) + m * m * m
                      â‰¤ m * m * m + m * m * m
      by apply uint_add_mono_less_equal to slack, mmm_le_mmm
    have cube_le_2mmm: (1 + m) * (1 + m) * (1 + m) â‰¤ 2 * (m * m * m) by {
      replace expand_cube
      replace uint_two_mult[m * m * m]
      step_combined
    }

    // Chain with the IH m*m*m â‰¤ 2^m to land at 2^(1+m) = 2 * 2^m.
    have two_mmm_le: 2 * (m * m * m) â‰¤ 2 * 2 ^ m
      by apply uint_mult_mono_le[2] to IH
    have pow_step: 2 ^ (1 + m) = 2 * 2 ^ m by uint_pow_add_r[2, 1, m]
    have cube_le_pow: (1 + m) * (1 + m) * (1 + m) â‰¤ 2 * 2 ^ m
      by apply uint_less_equal_trans to cube_le_2mmm, two_mmm_le
    replace pow_step
    cube_le_pow
  }
  expand P in apply uint_k_induction[P, 10] to base, ind
end

// Cubic is bounded by exponential: O(n^3) â‰² O(2^n). Threshold n0 = 10,
// constant c = 1 (uint_cube_le_2pow gives the pointwise inequality directly).
theorem bigo_cubic_le_2pow_n: O_n3 â‰² O_2pow_n
proof
  expand operatorâ‰² | O_n3 | O_2pow_n
  choose 10, 1
  arbitrary n:UInt
  assume ten_n: 10 â‰¤ n
  show n * n * n â‰¤ 1 * 2 ^ n
  apply uint_cube_le_2pow to ten_n
end
